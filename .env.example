# =====================================================
# BLUEPRINT DISCIPLESHIP INSTITUTE
# Environment Variables Template
# =====================================================
# Copy this to .env.local and fill in your values.
# Never commit .env.local to version control.

# =====================================================
# Supabase
# =====================================================
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-side only — never expose to the client
SUPABASE_SERVICE_ROLE_KEY=

# =====================================================
# OpenAI
# =====================================================
OPENAI_API_KEY=

# =====================================================
# App Config
# =====================================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Blueprint Discipleship Institute

# =====================================================
# Email (for application notifications, future)
# =====================================================
# RESEND_API_KEY=
# FROM_EMAIL=hello@theblueprintsfoundation.org
